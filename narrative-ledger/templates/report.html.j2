<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ p.decision.ticker }} — {{ p.decision.verdict }} · narrative-ledger</title>
<style>
  :root{
    --paper:#f6f3ec;--paper-2:#fbf9f4;--ink:#1f1b16;--ink-soft:#3a342c;--muted:#6f665a;--faint:#8b8275;
    --rule:#ddd5c6;--rule-strong:#c9bfac;--accent:#8c2f24;--accent-2:#2f4858;
    --pass:#3f6b4f;--caution:#9a6b1f;--fail:#9a3b2f;--chip:#efe9dd;
    --serif:Georgia,"Iowan Old Style","Palatino Linotype","Times New Roman",serif;
    --sans:-apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif;
    --mono:"SF Mono",ui-monospace,Menlo,Consolas,monospace;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--paper);color:var(--ink);font-family:var(--serif);font-size:17px;line-height:1.6;-webkit-font-smoothing:antialiased}
  .wrap{max-width:860px;margin:0 auto;padding:0 24px 90px}
  header{border-bottom:2px solid var(--ink);padding:38px 0 18px;margin-bottom:26px}
  .kicker{font-family:var(--sans);font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--accent);font-weight:700;margin-bottom:10px}
  h1{font-size:30px;line-height:1.12;margin:0 0 10px;letter-spacing:-.01em}
  .meta{font-family:var(--sans);font-size:12.5px;color:var(--muted);display:flex;flex-wrap:wrap;gap:6px 20px;border-top:1px solid var(--rule);padding-top:12px;margin-top:14px}
  .meta b{color:var(--ink-soft)}
  h2{font-size:21px;margin:38px 0 10px;padding-bottom:8px;border-bottom:1px solid var(--rule-strong)}
  .mono{font-family:var(--mono);font-size:12.5px;background:#ece6d9;padding:1px 5px;border-radius:4px}
  a{color:var(--accent);text-decoration:none;border-bottom:1px solid rgba(140,47,36,.32)}
  /* decision strip */
  .strip{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:1px;background:var(--rule-strong);border:1.5px solid var(--ink);border-radius:10px;overflow:hidden;margin:20px 0}
  .cell{background:var(--paper-2);padding:12px 14px}
  .cell .k{font-family:var(--sans);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);font-weight:700}
  .cell .v{font-size:20px;font-weight:700;margin-top:3px}
  .v-size{color:var(--pass)} .v-starter{color:var(--caution)} .v-wait{color:var(--accent-2)} .v-pass{color:var(--fail)}
  table{width:100%;border-collapse:collapse;font-family:var(--sans);font-size:13.5px;line-height:1.45;margin:14px 0}
  th,td{text-align:left;padding:9px 10px;border-bottom:1px solid var(--rule);vertical-align:top}
  thead th{background:var(--chip);font-size:11px;letter-spacing:.05em;text-transform:uppercase;border-bottom:1.5px solid var(--rule-strong)}
  .verdict-supports{color:var(--pass);font-weight:700}
  .verdict-refutes{color:var(--fail);font-weight:700}
  .verdict-insufficient{color:var(--caution);font-weight:700}
  blockquote{margin:4px 0 0;padding:2px 0 2px 10px;border-left:3px solid var(--rule-strong);color:var(--ink-soft);font-size:13px;font-style:italic}
  .ks li{margin-bottom:8px}
  .box{border-radius:10px;padding:14px 18px;margin:18px 0;font-size:15px;background:var(--paper-2);border:1px solid var(--rule);border-left:4px solid var(--accent-2)}
  .foot{font-family:var(--sans);font-size:12px;color:var(--muted);border-top:2px solid var(--ink);margin-top:56px;padding-top:14px}
  .pill{display:inline-block;font-family:var(--sans);font-size:10px;font-weight:700;letter-spacing:.05em;padding:1px 8px;border-radius:20px;text-transform:uppercase;background:var(--chip);color:var(--ink-soft)}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div class="kicker">narrative-ledger · run {{ p.run_id }}</div>
    <h1>{{ headline }}</h1>
    <div class="meta">
      <span><b>Source</b> {{ p.source.name }} ({{ p.source.track_record.status }})</span>
      <span><b>Published</b> {{ p.source.published_at.strftime("%d %b %Y") }}</span>
      <span><b>Run</b> {{ p.created_at.strftime("%d %b %Y") }}</span>
      <span><b>Artifact</b> <a href="{{ p.source.artifact_url }}">{{ p.source.artifact_url }}</a></span>
    </div>
  </header>

  <!-- THE DECISION — readable in 60 seconds -->
  <div class="strip">
    <div class="cell"><div class="k">Verdict</div><div class="v v-{{ p.decision.verdict }}">{{ p.decision.verdict | upper }}</div></div>
    <div class="cell"><div class="k">Expression</div><div class="v">{{ p.decision.direction }} {{ p.decision.ticker }}</div></div>
    <div class="cell"><div class="k">Conviction</div><div class="v">{{ "%.2f" | format(p.decision.conviction) }}</div></div>
    <div class="cell"><div class="k">Size (of vol budget)</div><div class="v">{{ "%.1f%%" | format(p.decision.size_frac * 100) }}</div></div>
    <div class="cell"><div class="k">Verified</div><div class="v">{{ verified }}/{{ total_lb }}</div></div>
    <div class="cell"><div class="k">Expectations gap</div><div class="v">{{ "%.2f" | format(p.priced_in.gap_score) }}</div></div>
    <div class="cell"><div class="k">Stage</div><div class="v">{{ p.priced_in.narrative_stage }}</div></div>
    <div class="cell"><div class="k">Horizon</div><div class="v">{{ p.decision.horizon_sessions }} sess</div></div>
  </div>

  <h2>Kill-switches — pre-registered</h2>
  <ul class="ks">
    {% for k in p.decision.kill_switches %}
    <li><span class="mono">{{ k.by_date }}</span> — {{ k.condition }}</li>
    {% endfor %}
  </ul>

  <h2>What's priced in</h2>
  <p><b>The price already requires:</b> {{ p.priced_in.expectations_summary }}</p>
  <p><b>Variant view:</b> {{ p.priced_in.variant_view }}</p>
  {% if p.priced_in.inputs %}
  <table>
    <thead><tr><th>Input</th><th>Value</th><th>Evidence</th></tr></thead>
    <tbody>
    {% for ref in p.priced_in.inputs %}
      <tr>
        <td>{{ ref.unit }}</td>
        <td class="mono">{{ ref.value }}</td>
        <td><a href="{{ ref.evidence.url }}">{{ ref.evidence.url.host }}</a> {% if ref.evidence.is_primary %}<span class="pill">primary</span>{% endif %}
          <blockquote>&ldquo;{{ ref.evidence.quote }}&rdquo;</blockquote></td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% endif %}

  <h2>Claims &amp; evidence</h2>
  <table>
    <thead><tr><th style="width:12%">Claim</th><th style="width:34%">Restatement</th><th style="width:12%">Verdict</th><th>Evidence</th></tr></thead>
    <tbody>
    {% for c in p.claims %}
      <tr>
        <td><span class="mono">{{ c.id }}</span><br><span class="pill">{{ c.type }}</span>{% if c.load_bearing %} <span class="pill" style="background:#f1ddd8;color:var(--accent)">load-bearing</span>{% endif %}</td>
        <td>{{ c.restatement }}<blockquote>&ldquo;{{ c.author_quote }}&rdquo;</blockquote></td>
        <td class="verdict-{{ c.verdict }}">{{ c.verdict or "—" }}</td>
        <td>
          {% for ev in c.evidence %}
          <div><a href="{{ ev.url }}">{{ ev.url.host }}</a> {% if ev.is_primary %}<span class="pill">primary</span>{% endif %}
          <blockquote>&ldquo;{{ ev.quote }}&rdquo;</blockquote></div>
          {% endfor %}
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>

  {% if p.outcome.realised_excess is not none %}
  <h2>Outcome — the loop, closed</h2>
  <div class="box">
    Realised excess ({{ p.decision.horizon_sessions }} sessions, benchmark-relative, direction-signed):
    <b>{{ "%+.2f%%" | format(p.outcome.realised_excess * 100) }}</b> —
    <b>{{ "HIT" if p.outcome.hit else "MISS" }}</b>, closed {{ p.outcome.closed_at.strftime("%d %b %Y") }}.
    {% if p.outcome.kill_switch_fired %}Kill-switch fired: {{ p.outcome.kill_switch_fired }}.{% endif %}
  </div>
  {% endif %}

  <h2>Source track record (computed, not asserted)</h2>
  <table>
    <thead><tr><th>Matured calls</th><th>Hit rate</th><th>Wilson 95% CI</th><th>Avg excess</th><th>Weight</th><th>Status</th></tr></thead>
    <tbody><tr>
      <td>{{ p.source.track_record.n_calls }}</td>
      <td>{{ "%.0f%%" | format(p.source.track_record.hit_rate * 100) }}</td>
      <td>[{{ "%.2f" | format(p.source.track_record.ci_low) }}, {{ "%.2f" | format(p.source.track_record.ci_high) }}]</td>
      <td>{{ "%+.2f%%" | format(p.source.track_record.avg_excess * 100) }}</td>
      <td>{{ "%.2f" | format(p.source.track_record.source_weight) }}</td>
      <td>{{ p.source.track_record.status }}</td>
    </tr></tbody>
  </table>

  <div class="foot">
    <p>Generated {{ generated_at }} by narrative-ledger. Payload schema {{ p.schema_version }}.
    Conviction = source weight × verification rate × expectations gap × stage; computed in code on cited inputs — the agent never runs the math.
    Research process, not investment advice.</p>
  </div>
</div>
</body>
</html>
